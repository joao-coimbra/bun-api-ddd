{
  "name": "bun-ddd-api-template",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/infra/server.ts",
    "build": "bun build src/infra/server.ts --target=bun --outdir=dist --minify --sourcemap",
    "start": "NODE_ENV=production bun dist/server.js",
    "test:e2e": "bun test/run-e2e.ts",
    "db:generate": "bun --bun drizzle-kit generate",
    "db:migrate": "bun --bun drizzle-kit migrate",
    "db:seed": "bun src/infra/database/seed.ts",
    "db:studio": "bun --bun drizzle-kit studio",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepare": "husky"
  },
  "dependencies": {
    "@elysiajs/bearer": "^1.4.4",
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/jwt": "^1.4.2",
    "@elysiajs/openapi": "^1.4.15",
    "archstone": "^1.5.4",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.28",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@elysiajs/eden": "^1.4.9",
    "@faker-js/faker": "^10.4.0",
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.10",
    "husky": "^9.1.7",
    "postgres": "^3.4.9",
    "ultracite": "7.6.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
