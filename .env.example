# Bun on the host + Postgres from `docker compose up` (published port):
DATABASE_URL=postgresql://docker:docker@localhost:5432/template
# Another service in the same Compose stack: use the service name, not localhost:
# DATABASE_URL=postgresql://docker:docker@postgres:5432/template

JWT_ACCESS_SECRET=jwt-access-secret
JWT_REFRESH_SECRET=jwt-refresh-secret

# Local E2E: `export` the variables above (or mirror .github/workflows/run-ci.yml) before `bun run test:e2e`.